+class Client::JsonForumTopics final : public td::Jsonable {
+ public:
+  JsonForumTopics(const td_api::forumTopics *topics, const Client *client)
+      : topics_(topics), client_(client) {
+  }
+  void store(td::JsonValueScope *scope) const {
+    auto object = scope->enter_object();
+    object("total_count", topics_->total_count_);
+    object("topics", td::json_array(topics_->topics_, [this](const auto &topic) {
