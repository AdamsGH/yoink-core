+td::Status Client::process_set_pinned_forum_topics_query(PromisedQueryPtr &query) {
+  auto chat_id = query->arg("chat_id");
+  auto ids_str = query->arg("forum_topic_ids");
+  td::vector<td::int32> topic_ids;
+  for (auto id_str : td::full_split(ids_str, ',')) {
+    topic_ids.push_back(td::to_integer<td::int32>(td::trim(id_str)));
+  }
+  check_chat(chat_id, AccessRights::Write, std::move(query),
+             [this, topic_ids = std::move(topic_ids)](int64 chat_id, PromisedQueryPtr query) mutable {
+               send_request(make_object<td_api::setPinnedForumTopics>(chat_id, std::move(topic_ids)),
+                            td::make_unique<TdOnOkQueryCallback>(std::move(query)));
+             });
+  return td::Status::OK();
+}
