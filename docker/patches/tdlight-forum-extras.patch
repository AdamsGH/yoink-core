+class Client::JsonForumTopic final : public td::Jsonable {
+ public:
+  JsonForumTopic(const td_api::forumTopic *topic, const Client *client)
+      : topic_(topic), client_(client) {
+  }
+  void store(td::JsonValueScope *scope) const {
+    auto object = scope->enter_object();
+    CHECK(topic_->info_ != nullptr);
+    object("message_thread_id", topic_->info_->forum_topic_id_);
+    object("name", topic_->info_->name_);
+    object("icon_color", topic_->info_->icon_->color_);
+    if (topic_->info_->icon_->custom_emoji_id_ != 0) {
+      object("icon_custom_emoji_id", td::to_string(topic_->info_->icon_->custom_emoji_id_));
+    }
+    object("is_closed", td::JsonBool(topic_->info_->is_closed_));
+    object("is_hidden", td::JsonBool(topic_->info_->is_hidden_));
+    object("is_general", td::JsonBool(topic_->info_->is_general_));
+    object("is_pinned", td::JsonBool(topic_->is_pinned_));
+    object("unread_count", topic_->unread_count_);
+    object("creation_date", topic_->info_->creation_date_);
+  }
+
+ private:
+  const td_api::forumTopic *topic_;
+  const Client *client_;
+};
