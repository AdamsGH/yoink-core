+class Client::JsonMessageReadDate final : public td::Jsonable {
+ public:
+  explicit JsonMessageReadDate(const td_api::MessageReadDate *read_date) : read_date_(read_date) {
+  }
+  void store(td::JsonValueScope *scope) const {
+    auto object = scope->enter_object();
+    switch (read_date_->get_id()) {
+      case td_api::messageReadDateRead::ID: {
+        const auto *d = static_cast<const td_api::messageReadDateRead *>(read_date_);
+        object("status", "read");
+        object("read_date", d->read_date_);
+        break;
+      }
+      case td_api::messageReadDateUnread::ID:
+        object("status", "unread");
+        break;
+      case td_api::messageReadDateTooOld::ID:
+        object("status", "too_old");
+        break;
+      case td_api::messageReadDateUserPrivacyRestricted::ID:
+        object("status", "user_privacy_restricted");
+        break;
+      case td_api::messageReadDateMyPrivacyRestricted::ID:
+        object("status", "my_privacy_restricted");
+        break;
+      default:
+        object("status", "unknown");
+    }
+  }
+
+ private:
+  const td_api::MessageReadDate *read_date_;
+};
