# Core
bot_token=
owner_id=
yoink_plugins=dl,stats,music,insight

# Local Bot API server (docker-compose.yml).
# Default uses official Telegram servers (50 MB upload limit).
# Set to http://yoink-tg-bot-api:8082/bot when running the local server (2 GB limit).
telegram_base_url=https://api.telegram.org/bot

# Telegram API credentials - required for the local Bot API server.
api_id=
api_hash=

# Host-mounted data directory. Must match the volume in docker-compose.yml.
# Contains: cookies/, tg-bot-api/ (user session token), kasm/
data_dir=/app/data

# Database
database_url=postgresql+asyncpg://yoink:yoink@yoink-postgres:5432/yoink
database_echo=false

# API server
api_port=8000
api_secret_key=change-me-in-production
api_token_expire_minutes=1440

# Misc
debug=false
json_logs=false
default_language=en

# Proxy - used by dl plugin (proxy_urls) and MUSIC_PROXY_URL via substitution.
# proxy_url is a convenience alias; proxy_urls is the actual list used by dl.
proxy_url=socks5://host.docker.internal:1080
proxy_urls=["socks5://host.docker.internal:1080"]

# Domains routed through proxy_urls in dl plugin.
proxy_domains=["tiktok.com","vm.tiktok.com","vt.tiktok.com","e621.net"]

# Rate limiting (dl plugin defaults; can be overridden per-user)
rate_limit_per_minute=5
rate_limit_per_hour=30
rate_limit_per_day=100

# Download limits
max_file_size_gb=2.0
max_playlist_count=50
download_timeout=1200

# yt-dlp POT provider (bgutil, docker-compose.yml).
# Leave youtube_pot_enabled=false to disable.
youtube_pot_enabled=false
youtube_pot_url=http://yoink-bgutil:4416

# Proxy for bgutil outbound traffic.
bgutil_proxy=${proxy_url}

# Browser-based cookie extraction (yt-dlp --cookies-from-browser).
# Populated by yoink-browser (profile: cookies). Leave empty to disable.
browser_profile_path=
browser_cookie_domains=["youtube.com","googlevideo.com","google.com","tiktok.com","www.tiktok.com"]

# yoink-browser (Kasmweb Chromium) - only used with profile: cookies
kasm_vnc_pw=changeme
kasm_launch_url=https://www.youtube.com

# Cookie pool - optional per-user account info enrichment
# Fetches real name/avatar from YouTube/Instagram/Twitter APIs on cookie upload.
# Leave empty to skip enrichment (cookies still work without it).
# YOUTUBE_INNERTUBE_KEY is not required - the default public key is used.
# INSTAGRAM_SESSION_ID is the sessionid cookie from an Instagram session.
cookie_youtube_sapisid=
cookie_instagram_session_id=

# IPv6 rotation for yt-dlp / gallery-dl outbound requests.
# Requires a routed /56 (or larger) prefix assigned to the host.
# Disabled by default - ISP must route the prefix to the Docker host.
# IPV6_DOMAINS: comma-separated domains to route through IPv6 (e.g. youtube.com,youtu.be)
IPV6_CIDR=
IPV6_DOMAINS=

# yoink-music plugin
MUSIC_SPOTIFY_CLIENT_ID=
MUSIC_SPOTIFY_CLIENT_SECRET=
MUSIC_PROXY_URL=${proxy_url}
MUSIC_PROXY_PLATFORMS=spotify,soundcloud
MUSIC_DOWNLOAD_ENABLED=false

# yoink-insight plugin
gemini_api_key=
gemini_model=gemini-3-flash-preview
# insight_default_lang=en
# insight_transcript_langs=en,ru

# Logging channels (optional)
log_channel=
log_exception_channel=

# Traefik domain for the frontend (traefik-kop)
yoink_domain=yoink.example.com

# S3 backup (optional - requires profile: backup)
backup_s3_endpoint=
backup_s3_bucket=yoink-backups
backup_s3_access_key=
backup_s3_secret_key=
backup_s3_region=garage
backup_retain_daily=7
backup_retain_weekly=4
backup_cron_schedule=0 3 * * *

# Dev auth — /auth/dev endpoint for local development
# Restricted to DEV_ALLOWED_CIDR by nginx; never reachable from the internet.
# Set to your local network CIDR (e.g. 192.168.1.0/24 or 10.0.0.0/8).
DEV_AUTH_ENABLED=false
DEV_ALLOWED_CIDR=192.168.0.0/16
