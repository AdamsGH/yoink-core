bot_token=
owner_id=

# Local Bot API server (docker-compose.infra.yml).
# Leave default to use official Telegram servers (50MB upload limit).
# Set to http://yoink-tg-bot-api:8082/bot when infra is running (2GB limit).
telegram_base_url=https://api.telegram.org/bot

# Host-mounted data directory. Must match the volume mount in docker-compose.yml.
# Contains: cookies/, tg-bot-api/ (user session token), kasm/
data_dir=/app/data

yoink_plugins=

database_url=postgresql+asyncpg://yoink:yoink@yoink-postgres:5432/yoink
database_echo=false

api_port=8000
api_secret_key=change-me-in-production
api_token_expire_minutes=1440
debug=false
json_logs=false

default_language=en

rate_limit_per_minute=5
rate_limit_per_hour=30
rate_limit_per_day=100

log_channel=
log_exception_channel=

# Infra: local Bot API server (docker-compose.infra.yml)
api_id=
api_hash=

# Proxy for tg-bot-api outbound traffic (e.g. via WireGuard HTTP proxy).
# Example: http://host.docker.internal:8580
tg_bot_api_proxy=

# Proxy for bgutil yt-dlp POT provider.
# Example: socks5://host.docker.internal:1080
bgutil_proxy=

# yt-dlp POT provider URL (bgutil, docker-compose.infra.yml).
# Leave empty to disable.
youtube_pot_url=http://bgutil-provider:4416

# Browser profile for automatic cookie extraction via yt-dlp --cookies-from-browser.
# Populated by yoink-browser (docker-compose.infra.yml, profile: cookies).
# Volume: ./data/kasm/profile/chromium -> /app/data/browser-profile (ro)
# Leave empty to disable browser-based cookies.
browser_profile_path=

# yoink-browser (kasm-chromium) settings - only used with profile: cookies
kasm_vnc_pw=changeme
kasm_launch_url=https://www.youtube.com

# Traefik domain for the frontend (traefik-kop)
yoink_domain=yoink.saintvegas.cc

# S3 backup (optional - backup is disabled unless all 4 values are set)
# Enable the backup profile: docker compose --profile backup up -d
backup_s3_endpoint=
backup_s3_bucket=yoink-backups
backup_s3_access_key=
backup_s3_secret_key=
backup_s3_region=garage
backup_retain_daily=7
backup_retain_weekly=4
backup_cron_schedule=0 3 * * *
